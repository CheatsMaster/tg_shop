{
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/webapp/dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/webapp/dist/index.html"
    }
  ]
}